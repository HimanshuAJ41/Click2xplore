.wonder-toast-dismiss:hover { background: rgba(234,67,53,0.2); color: #EA4335; }

/* On mobile: move to bottom-center, smaller */
@media (max-width: 768px) {
    .wonder-toast-container {
        left: 50%;
        transform: translateX(-50%);
        bottom: 56px;
        align-items: center;
    }
    .wonder-toast {
