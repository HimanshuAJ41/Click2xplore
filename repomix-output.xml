    transform: translateX(0) scale(1);
}

.wonder-toast.dismissing {
    opacity: 0;
    transform: translateX(-20px) scale(0.95);
    transition: opacity 0.3s ease, transform 0.3s ease;
}

/* Shimmer accent line at top */
.wonder-toast::before {
