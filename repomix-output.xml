.ddown-icon-btn.my-location-style { color: #4285F4; border-color: rgba(66,133,244,0.3); }
.ddown-icon-btn.my-location-style:hover { background: rgba(66,133,244,0.15); }

/* Search Autocomplete Suggestions */
.search-suggestions {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: rgba(15, 15, 30, 0.96);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-md);
    max-height: 320px;
    overflow-y: auto;
    z-index: 2000;
    display: none;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
    animation: suggestFadeIn 0.2s ease;
}

.search-suggestions.active {
    display: block;
}

@keyframes suggestFadeIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
}

.search-suggestions::-webkit-scrollbar {
