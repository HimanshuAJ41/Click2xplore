}
.ddown-btn:hover { background: rgba(255,255,255,0.1); color: var(--text-primary); }
.ddown-btn.active { background: rgba(99,102,241,0.2); border-color: var(--primary); color: var(--text-primary); }

.ddown-icon-btn {
