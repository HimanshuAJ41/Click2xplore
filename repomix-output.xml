            <div class="coordinates">
                <span>📍</span>
                <span id="live-location-name" class="location-name-live">Earth</span>
                <span class="coord-separator">|</span>
                <span id="live-coords">0.0000°, 0.0000°</span>
            </div>
            <div class="footer-info">
                <span>Powered by Cesium.js</span>
            </div>
        </footer>
    </div>

    <script src="info-panel.js"></script>
    <script src="navigation.js"></script>
    <script src="places-db.js"></script>
    <script src="app.js"></script>

    <script>
        // ── Controls dropdown toggle ──────────────────────────────
        const menuBtn = document.getElementById('controls-menu-btn');
        const dropdown = document.getElementById('controls-dropdown');

        menuBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('open');
        });
        document.addEventListener('click', () => dropdown.classList.remove('open'));
        dropdown.addEventListener('click', e => e.stopPropagation());

        // ── Mobile search toggle ──────────────────────────────────
        const searchToggle = document.getElementById('search-toggle-btn');
        const searchInput = document.getElementById('search-input');
        const searchBtn = document.getElementById('search-btn');

        if (searchToggle) {
            searchToggle.addEventListener('click', (e) => {
                e.stopPropagation();
                searchInput.classList.toggle('search-open');
                searchBtn.classList.toggle('search-open');
                if (searchInput.classList.contains('search-open')) {
                    searchInput.focus();
                }
            });
            document.addEventListener('click', (e) => {
                if (!e.target.closest('.search-container')) {
                    searchInput.classList.remove('search-open');
                    searchBtn.classList.remove('search-open');
                }
            });
        }

        // ── Dropdown view buttons (mobile) ────────────────────────
        document.querySelectorAll('.ddown-btn[data-view]').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.ddown-btn[data-view]').forEach(b => b.classList.remove('active'));
                // Also sync desktop nav-btn
                document.querySelectorAll('.nav-btn').forEach(b => {
                    b.classList.toggle('active', b.dataset.view === btn.dataset.view);
                });
                btn.classList.add('active');
                if (typeof changeView === 'function') changeView(btn.dataset.view);
                dropdown.classList.remove('open');
            });
        });

        // ── Dropdown control buttons ──────────────────────────────
        function bindDD(ddId, realId) {
            const ddBtn = document.getElementById(ddId);
            const realBtn = document.getElementById(realId);
            if (ddBtn && realBtn) {
                ddBtn.addEventListener('click', () => {
                    realBtn.click();
                    dropdown.classList.remove('open');
                });
            }
        }
        bindDD('dd-zoom-in', 'zoom-in');
        bindDD('dd-zoom-out', 'zoom-out');
        bindDD('dd-rotate-left', 'rotate-left');
        bindDD('dd-rotate-right', 'rotate-right');
        bindDD('dd-reset-view', 'reset-view');
        bindDD('dd-my-location', 'my-location');
    </script>
</body>

</html>
