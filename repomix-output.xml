}
.search-toggle-btn svg { width: 18px; height: 18px; }

/* Controls dropdown wrapper */
.controls-menu-wrap {
    position: relative;
    flex-shrink: 0;
}

.controls-menu-btn {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
